# InvesCore Slide Studio — backend environment variables
#
# Copy to .env (or set in Railway dashboard) and edit as needed. All values
# below are the runtime defaults; everything is optional.

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allow-list. Wildcards are explicitly rejected (the BYO-key
# model means open CORS is an open AI-cost-laundering proxy).
CORS_ALLOW_ORIGINS=https://invescore-slide-studio.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# ── Request / artifact limits ────────────────────────────────────────────────
# Hard caps enforced before any Anthropic call. Defense-in-depth against
# DoS-via-cost on user keys.
MAX_REQUEST_BYTES=262144            # 256 KB request body cap
ARTIFACT_TTL_SECONDS=21600          # 6 h retention for generated decks

# ── Builder concurrency / retry ──────────────────────────────────────────────
# How many slides to call the Builder Agent for in parallel. Anthropic Tier 1
# accounts may need a lower value (e.g. 3); Tier 2+ users can raise it.
BUILDER_CONCURRENCY=6
BUILDER_RETRIES=3                   # exponential backoff on 429/500/502/503/529

# ── SSE keep-alive ───────────────────────────────────────────────────────────
# Heartbeat interval (": hb" comments) to keep idle SSE connections from being
# killed by upstream proxies (Cloudflare, corporate firewalls, etc.).
SSE_HEARTBEAT_SEC=15

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # CRITICAL | ERROR | WARNING | INFO | DEBUG
UVICORN_ACCESS_LEVEL=WARNING        # Suppress uvicorn's per-request access log
